# General
DATABASE_URL="file:../prisma/prod.db"
JWT_SECRET=your_super_secret_jwt_key_here
PORT=5000
CORS_ORIGIN=https://vaultiq.yourdomain.com
FRONTEND_URL=https://vaultiq.yourdomain.com
REDIS_URL=redis://redis:6379

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/cloud/auth/google/callback

# Dropbox OAuth
DROPBOX_CLIENT_ID=your_dropbox_client_id
DROPBOX_CLIENT_SECRET=your_dropbox_client_secret
DROPBOX_REDIRECT_URI=https://api.yourdomain.com/api/cloud/auth/dropbox/callback

# OneDrive OAuth
ONEDRIVE_CLIENT_ID=your_onedrive_client_id
ONEDRIVE_CLIENT_SECRET=your_onedrive_client_secret
ONEDRIVE_REDIRECT_URI=https://api.yourdomain.com/api/cloud/auth/onedrive/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://api.yourdomain.com/api/cloud/auth/github/callback

# Frontend (Production Build)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
