# Auth
JWT_SECRET=your_super_secret_jwt_key_here
NEXTAUTH_URL=https://vaultmind.vercel.app

# Database (Supabase / Neon)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://vaultmind.vercel.app/api/cloud/auth/google/callback

# Dropbox OAuth
DROPBOX_CLIENT_ID=your_dropbox_client_id
DROPBOX_CLIENT_SECRET=your_dropbox_client_secret
DROPBOX_REDIRECT_URI=https://vaultmind.vercel.app/api/cloud/auth/dropbox/callback

# OneDrive OAuth
ONEDRIVE_CLIENT_ID=your_onedrive_client_id
ONEDRIVE_CLIENT_SECRET=your_onedrive_client_secret
ONEDRIVE_REDIRECT_URI=https://vaultmind.vercel.app/api/cloud/auth/onedrive/callback

# General
FRONTEND_URL=https://vaultmind.vercel.app
